{
  "entities": {
    "Agent": {
      "title": "Agent",
      "description": "User profile with agent capabilities and tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "momoNumber": { "type": "string" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string", "description": "UID of the agent who referred this user" },
        "role": { "type": "string", "enum": ["user", "agent", "admin"] },
        "stats": {
          "type": "object",
          "properties": {
            "totalSales": { "type": "number" },
            "commissionEarned": { "type": "number" },
            "designsApproved": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Apparel product items in the shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "gsmPrices": { "type": "object" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "allowedColors": { "type": "array", "items": { "type": "string" } },
        "colorStudioImages": { "type": "object" },
        "colorBlueprints": { "type": "object" },
        "colorImages": { "type": "object" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "mockupImage": { "type": "string" },
        "studioImage": { "type": "string" },
        "blueprintImage": { "type": "string" },
        "agentId": { "type": "string" },
        "agentName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "basePrice", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order records",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "depositAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "momoReference": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "partially_paid", "completed", "cancelled"] },
        "agentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["totalAmount", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "User feedback on products",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "comment"]
    },
    "Payout": {
      "title": "Payout",
      "description": "Payment records to agents",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processed", "failed"] },
        "method": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "amount", "status"]
    }
  },
  "firestore": {
    "/agents/{agentId}": {
      "schema": "Agent",
      "description": "Agent profiles indexed by UID"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "All products including agent designs"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific product"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/payouts/{payoutId}": {
      "schema": "Payout",
      "description": "Agent payout records"
    }
  }
}
